# -------------------------------------------------------
# FamilyAdmin — Production Environment Variables
# Copy to .env and fill in all values before first run.
# NEVER commit .env to git.
# -------------------------------------------------------

# Database
POSTGRES_DB=familyadmin
POSTGRES_USER=familyadmin
POSTGRES_PASSWORD=change-me-use-a-strong-password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=

# Domain — just the bare domain, no protocol (e.g. familyadmin.example.com)
# Caddy will serve frontend at https://$APP_DOMAIN
#              and backend at https://api.$APP_DOMAIN
APP_DOMAIN=familyadmin.yourdomain.com

# Used by Spring Boot CORS (with https://)
APP_FRONTEND_URL=https://familyadmin.yourdomain.com

# Used by Next.js at build time to reach the backend from the browser
NEXT_PUBLIC_API_URL=https://api.familyadmin.yourdomain.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
