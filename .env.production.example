# -------------------------------------------------------
# FamilyAdmin — Production Environment Variables
# Copy to .env and fill in all values before first run.
# NEVER commit .env to git.
# -------------------------------------------------------

# Database
POSTGRES_DB=familyadmin
POSTGRES_USER=familyadmin
POSTGRES_PASSWORD=change-me-use-a-strong-password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=

# Domain — bare domain only, no protocol (e.g. familyadmin.baier-family.de)
# Caddy serves frontend at https://$APP_DOMAIN
# and proxies /api/* to the backend on the same domain
APP_DOMAIN=familyadmin.baier-family.de

# Must match https://$APP_DOMAIN — used by Spring Boot for CORS
APP_FRONTEND_URL=https://familyadmin.baier-family.de

# Same domain — Caddy proxies /api/* to the backend
NEXT_PUBLIC_API_URL=https://familyadmin.baier-family.de

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
