# ============================================================
# FamilyAdmin Backend — Required Railway Environment Variables
# ============================================================
# Copy these variable names into your Railway service settings.
# Never commit real values to git.

# ----------------------------------------------------------
# Database — from Railway PostgreSQL plugin
# Use Railway variable references: ${{Postgres.JDBC_URL}} etc.
# ----------------------------------------------------------
DATABASE_URL=jdbc:postgresql://host:5432/dbname
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=secret

# ----------------------------------------------------------
# JWT — generate with: openssl rand -base64 64
# ----------------------------------------------------------
JWT_SECRET=your-very-long-random-secret-here

# ----------------------------------------------------------
# Spring profile — must be "prod" on Railway
# ----------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

# ----------------------------------------------------------
# Email (Resend SMTP — https://resend.com)
# ----------------------------------------------------------
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_resend_api_key

# ----------------------------------------------------------
# Frontend URL — for CORS allow-list
# Replace with your actual Railway frontend service URL
# ----------------------------------------------------------
APP_FRONTEND_URL=https://your-frontend.up.railway.app

# ----------------------------------------------------------
# JVM tuning (optional — set in Railway start command or here)
# ----------------------------------------------------------
# JAVA_OPTS=-Xmx400m -Xss512k
