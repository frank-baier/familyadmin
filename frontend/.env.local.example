# FamilyAdmin — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and should never be committed.

# Public API URL (used by browser-side fetches and Client Components)
# On Railway, this will be the public URL of the Spring Boot backend service.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Internal API URL (used by Server Components and Route Handlers — server-side only)
# On Railway, use the internal service URL for lower latency:
# API_URL=http://backend.railway.internal:8080
API_URL=http://localhost:8080
